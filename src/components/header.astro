---
import Theme from "./theme.astro";
---

<div class="pl-8 md:px-[25%] pt-8 font-medium font-sans">
    <div
        class="flex flex-col md:flex-row items-start md:items-center md:justify-between gap-4 md:gap-0"
    >
        <a href="/"
            ><h1 class="hover:text-neutral-900 dark:hover:text-neutral-200">
                Stavros <span class="text-blue-500">@steveiliop56</span>
            </h1></a
        >
        <nav class="text-md flex flex-row items-center gap-4">
            <a
                href="/projects"
                class="hover:text-neutral-900 dark:hover:text-neutral-200"
                >Projects</a
            >
            <a
                href="/blog"
                class="hover:text-neutral-900 dark:hover:text-neutral-200"
                >Blog</a
            >
            <a
                href="/contact"
                class="hover:text-neutral-900 dark:hover:text-neutral-200"
                >Contact</a
            >
            <Theme />
        </nav>
    </div>
</div>
